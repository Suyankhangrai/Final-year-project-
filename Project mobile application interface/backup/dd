def create_schedule(pet_id, label, feed_time, portion_grams, days, device_id=1):
    conn = get_db()
    cur = conn.cursor()
    cur.execute("SET FOREIGN_KEY_CHECKS = 0")
    
    # Updated to include 'days' and match the 6 variables below
    cur.execute("""
        INSERT INTO feeding_schedules
          (pet_id, device_id, label, feed_time, portion_grams, days, is_active, created_at)
        VALUES (%s, %s, %s, %s, %s, %s, TRUE, NOW())
    """, (pet_id, device_id, label, feed_time, portion_grams, days))
    
    cur.execute("SET FOREIGN_KEY_CHECKS = 1")
    conn.commit()
    cur.close()
    conn.close()

def get_all_schedules():
    conn = get_db()
    cur = conn.cursor(dictionary=True)
    # Join with pets to get the pet_name for the UI
    cur.execute("""
        SELECT s.schedule_id, s.feed_time, s.portion_grams as grams, 
               s.days, s.is_active, p.pet_name 
        FROM feeding_schedules s
        JOIN pets p ON s.pet_id = p.pet_id
    """)
    rows = cur.fetchall()
    cur.close()
    conn.close()
    return rows

def get_active_schedules():
    conn = get_db()
    cur = conn.cursor(dictionary=True)
    cur.execute("""
        SELECT s.schedule_id, s.feed_time, s.portion_grams, 
               s.days, p.pet_name, p.pet_id
        FROM feeding_schedules s
        JOIN pets p ON s.pet_id = p.pet_id
        WHERE s.is_active = TRUE
    """)
    rows = cur.fetchall()
    cur.close()
    conn.close()
    
    # Format time for the scheduler logic
    for row in rows:
        td = row["feed_time"]
        if hasattr(td, "total_seconds"):
            total = int(td.total_seconds())
            row["feed_time"] = f"{total // 3600:02d}:{(total % 3600) // 60:02d}"
    return rows

