def get_pending_command():
    conn = get_db()
    cur = conn.cursor(dictionary=True)
    # Looks for the oldest pending manual feed request
    cur.execute("SELECT * FROM manual_feeds WHERE status = 'pending' ORDER BY created_at ASC LIMIT 1")
    command = cur.fetchone()
    if command:
        # Mark it as 'processing' so it doesn't feed twice
        cur.execute("UPDATE manual_feeds SET status = 'completed' WHERE id = %s", (command['id'],))
        conn.commit()
    cur.close()
    conn.close()
    return command

